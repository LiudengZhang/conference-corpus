# Separate public repo, cloned here as a working copy
_awesome-virtual-cell/

# Claude Code project metadata
.claude/

# macOS
.DS_Store

# Large binary artifacts (PDFs downloaded on demand, not versioned)
**/pdfs/
*.pdf

# Temporary/scratch
/tmp/
/_scratch/

# MkDocs build output
site/
# Cloudflare Pages local state
.wrangler/

# Generated at build time
docs/assets/*-posters.json
docs/javascripts/tabulator.min.js
docs/sessions/*.md
!docs/sessions/index.md

docs/stylesheets/tabulator.min.css

# Python bytecode
__pycache__/
*.py[cod]

# Build-generated files (regenerated by scripts/build_site.py on each build)
docs/conferences/*/sessions/
docs/assets/*/posters/
docs/assets/*/bioinfo-tools/

# Baseline snapshot for refactor validation
_baseline/
